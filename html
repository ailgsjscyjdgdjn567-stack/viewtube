async function delVid(id){
  if(!CU)return;const vids=await GV()||[];const v=vids.find(x=>x.id===id);
  if(!v||v.author!==CU.username){toast('Нельзя удалить чужое','err');return;}
  await SV(vids.filter(x=>x.id!==id));
  if(v.type==='local'){const b=await GB(CU.username)||{};delete b[id];await SB(CU.username,b);}
  allVids=allVids.filter(x=>x.id!==id);toast('🗑 Удалено','ok');loadPage(curPage);
}
