  if(ch===CU.username){toast('Нельзя на себя','err');return;}
  const subs=await GS()||{};if(!subs[CU.username])subs[CU.username]=[];
  const arr=subs[CU.username],idx=arr.indexOf(ch);const sb=document.getElementById('subBtn');
  if(idx===-1){arr.push(ch);sb.className='actb subbed';sb.textContent='✅ Подписан';SS(subs);
    // Push notification to channel owner
    await pushNotif(ch,CU.username,v.title,v.id);
  }else{arr.splice(idx,1);sb.className='actb';sb.textContent='🔔 Подписаться';SS(subs);}
  document.getElementById('wChS').textContent=Object.values(subs).filter(s=>s.includes(ch)).length+' подписчиков';
}

// ══════════ COMMENTS ══════════
let cmtSortByLikes=false;
async function renderComments(vidId){
  let cmts=await GC(vidId)||[];const cr=await GCR(vidId)||{};
  if(cmtSortByLikes)cmts=[...cmts].sort((a,b)=>(b.likes||0)-(a.likes||0));
  document.getElementById('cmtCount').textContent='('+cmts.length+')';
  document.getElementById('cmtSortLbl').textContent=cmtSortByLikes?'По лайкам':'По времени';
  const fa=document.getElementById('cmtFormArea');
  if(CU){const prof=await getProf(CU.username);const col=gc(CU.username);const bg=prof.avatarDataUrl?'transparent':col;
    fa.innerHTML=`<div class="comment-form"><div class="comm-av" style="background:${bg};">${avH(prof,CU.username)}</div><div class="comm-input-wrap"><textarea class="comm-input" id="cmtIn" placeholder="Написать комментарий..." rows="1" oninput="this.style.height='auto';this.style.height=this.scrollHeight+'px'"></textarea><div class="comm-actions" id="cmtActs" style="display:none;"><button class="comm-cancel" onclick="document.getElementById('cmtIn').value='';document.getElementById('cmtActs').style.display='none';">Отмена</button><button class="comm-send" onclick="postComment('${vidId}')">📤 Отправить</button></div></div></div>`;
    document.getElementById('cmtIn').addEventListener('focus',()=>document.getElementById('cmtActs').style.display='flex');
  }else{fa.innerHTML=`<div class="guest-hint">Войдите <span onclick="document.getElementById('authMod').classList.add('open')">чтобы комментировать</span></div>`;}
  const cl=document.getElementById('cmtList');
  if(!cmts.length){cl.innerHTML=`<div style="text-align:center;padding:20px;font-size:13px;color:var(--mut);">Комментариев нет — будьте первым!</div>`;return;}
  const profC={};for(const c of cmts.slice(0,30)){if(!profC[c.author])profC[c.author]=await getProf(c.author);}
  cl.innerHTML=cmts.slice(0,30).map(c=>{
    const p=profC[c.author];const col=gc(c.author);const bg=p?.avatarDataUrl?'transparent':col;
    const myR=CU?cr[CU.username+'_'+c.id]||'':'';
    return`<div class="comment-item">
      <div class="ci-av" style="background:${bg};">${avH(p,c.author)}</div>
      <div class="ci-body">
        <div class="ci-name">${escH(p?.displayName||c.author)}</div>
        <div class="ci-text">${escH(c.text)}</div>
        <div class="ci-footer">
          <span class="ci-time">${ago(c.date)}</span>
          <button class="ci-react ${myR==='like'?'active-like':''}" onclick="reactCmt('${vidId}','${c.id}','like')">👍 ${c.likes||0}</button>
          <button class="ci-react ${myR==='dis'?'active-dis':''}" onclick="reactCmt('${vidId}','${c.id}','dis')">👎 ${c.dislikes||0}</button>
        </div>
      </div>
    </div>`;
  }).join('');
}
function toggleCmtSort(){cmtSortByLikes=!cmtSortByLikes;if(curVid)renderComments(curVid);}
async function postComment(vidId){
  const inp=document.getElementById('cmtIn');const text=inp?.value.trim();if(!text||!CU)return;
  const cmts=await GC(vidId)||[];cmts.push({id:'c'+Date.now(),author:CU.username,text,date:Date.now(),likes:0,dislikes:0});
  await SC(vidId,cmts);inp.value='';inp.style.height='auto';document.getElementById('cmtActs').style.display='none';
  await renderComments(vidId);toast('💬','ok');
}
async function reactCmt(vidId,cmtId,type){
  if(!CU){toast('Войдите','err');return;}
  const cmts=await GC(vidId)||[];const cr=await GCR(vidId)||{};
  const c=cmts.find(x=>x.id===cmtId);if(!c)return;
  const key=CU.username+'_'+cmtId;const prev=cr[key]||'';
  if(prev===type){cr[key]='';if(type==='like')c.likes=Math.max(0,(c.likes||1)-1);else c.dislikes=Math.max(0,(c.dislikes||1)-1);}
  else{if(prev==='like')c.likes=Math.max(0,(c.likes||1)-1);if(prev==='dis')c.dislikes=Math.max(0,(c.dislikes||1)-1);cr[key]=type;if(type==='like')c.likes=(c.likes||0)+1;else c.dislikes=(c.dislikes||0)+1;}
  await SC(vidId,cmts);await SCR(vidId,cr);renderComments(vidId);
}

// ══════════ UPLOAD ══════════
function ytId(url){if(!url)return null;const m=url.match(/(?:v=|youtu\.be\/|embed\/|shorts\/)([a-zA-Z0-9_-]{11})/);return m?m[1]:null;}
function prevYT(){const id=ytId(document.getElementById('upUrl').value);const b=document.getElementById('upPrev');if(id){b.innerHTML=`<iframe src="https://www.youtube.com/embed/${id}" allowfullscreen style="width:100%;height:100%;border:none;"></iframe>`;b.classList.add('hc');}else{b.innerHTML='🎬';b.classList.remove('hc');}}
function setUT(t){upType=t;['link','file'].forEach(x=>{document.getElementById('tab-'+x).classList.toggle('active',t===x);document.getElementById('pan-'+x).classList.toggle('active',t===x);});}
// Tags
function handleTag(e){if(e.key==='Enter'||e.key===','){ e.preventDefault();const v=document.getElementById('tagInput').value.trim().replace(/,$/,'');if(v&&!uploadTags.includes(v)&&uploadTags.length<8){uploadTags.push(v);renderTags();}document.getElementById('tagInput').value='';}}
function renderTags(){const wrap=document.getElementById('tagsWrap');const inp=document.getElementById('tagInput');wrap.innerHTML=uploadTags.map((t,i)=>`<div class="tag-pill">#${escH(t)}<button onclick="removeTag(${i})">×</button></div>`).join('');wrap.appendChild(inp);inp.focus();}
function removeTag(i){uploadTags.splice(i,1);renderTags();}
function dzDrag(e){e.preventDefault();document.getElementById('dz').classList.add('drag');}
function dzLeave(){document.getElementById('dz').classList.remove('drag');}
function dzDrop(e){e.preventDefault();dzLeave();const f=e.dataTransfer?.files?.[0];if(f&&f.type.startsWith('video/'))handleFile(f);}
function onFS(inp){const f=inp.files?.[0];if(f)handleFile(f);}
function handleFile(file){if(file.size>210*1024*1024){toast('Макс. 200 МБ','err');return;}document.getElementById('dzFN').textContent='✅ '+file.name;const pv=document.getElementById('filePrev'),vid=document.getElementById('pvid');vid.src=URL.createObjectURL(file);pv.style.display='';if(!document.getElementById('upTitle').value)document.getElementById('upTitle').value=file.name.replace(/\.[^.]+$/,'');window._upFile=file;}
async function doUpload(){
  if(!CU){toast('Войдите','err');return;}
  const title=document.getElementById('upTitle').value.trim(),desc=document.getElementById('upDesc').value.trim(),cat=document.getElementById('upCat').value;
  if(!title){toast('Введите название','err');return;}
  if(upType==='link'){
    const url=document.getElementById('upUrl').value.trim();if(!url||!ytId(url)){toast('Неверная ссылка YouTube','err');return;}
    const newId=ytId(url);const existing=await GV()||[];if(existing.find(v=>v.type!=='local'&&ytId(v.url)===newId)){toast('Уже добавлено','err');return;}
    const vid={id:'v'+Date.now(),url,type:'yt',title,description:desc,category:cat,tags:uploadTags.slice(),author:CU.username,date:Date.now(),likes:0,dislikes:0,views:0};
    await saveVid(vid);
    // Notify subscribers
    const subs=await GS()||{};
    for(const [user,channels] of Object.entries(subs)){if(channels.includes(CU.username))await pushNotif(user,CU.username,title,vid.id);}
  }else{
    const file=window._upFile;if(!file){toast('Выберите файл','err');return;}
    document.getElementById('pbar').style.display='';
    await new Promise((res,rej)=>{const reader=new FileReader();reader.onprogress=e=>{if(e.lengthComputable)document.getElementById('pfill').style.width=(e.loaded/e.total*100)+'%';};reader.onload=async()=>{const id='v'+Date.now();document.getElementById('pfill').style.width='100%';try{const b=await GB(CU.username)||{};b[id]=reader.result;await SB(CU.username,b);await saveVid({id,type:'local',title,description:desc,category:cat,tags:uploadTags.slice(),author:CU.username,date:Date.now(),likes:0,dislikes:0,views:0});res();}catch(e){toast('Ошибка','err');rej(e);}};reader.onerror=rej;reader.readAsDataURL(file);});
    document.getElementById('pbar').style.display='none';document.getElementById('pfill').style.width='0%';
  }
  document.getElementById('upUrl').value='';document.getElementById('upTitle').value='';document.getElementById('upDesc').value='';
  document.getElementById('upPrev').innerHTML='🎬';document.getElementById('upPrev').classList.remove('hc');
  document.getElementById('dzFN').textContent='';document.getElementById('filePrev').style.display='none';document.getElementById('pvid').src='';
  uploadTags=[];renderTags();window._upFile=null;
  toast('🎉 Опубликовано!','ok');showPage('home');
}
async function saveVid(obj){const vids=await GV()||[];vids.unshift(obj);await SV(vids);allVids=vids;}

// ══════════ UTILS ══════════
function ago(ts){const d=(Date.now()-ts)/1000;if(d<60)return'только что';if(d<3600)return Math.floor(d/60)+'м';if(d<86400)return Math.floor(d/3600)+'ч';if(d<2592000)return Math.floor(d/86400)+'д';return Math.floor(d/2592000)+'мес';}
let _tT;
function toast(msg,type=''){const el=document.getElementById('toast');el.textContent=msg;el.className='toast'+(type?' '+type:'');el.classList.add('show');clearTimeout(_tT);_tT=setTimeout(()=>el.classList.remove('show'),2800);}

// ══════════ INIT ══════════
(async()=>{
  await loadSettings();
  await renderHeader();
  await updateMobAv();
  await loadPage('home');
})();
</script>
