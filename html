function swF(f){document.getElementById('loginF').style.display=f==='login'?'':'none';document.getElementById('regF').style.display=f==='reg'?'':'none';document.getElementById('linErr').textContent='';document.getElementById('regErr').textContent='';}
async function doLogin(){
  const u=document.getElementById('linU').value.trim(),p=document.getElementById('linP').value;
  if(!u||!p){document.getElementById('linErr').textContent='Заполните поля';return;}
  const users=await GU()||{};
  if(!users[u]){document.getElementById('linErr').textContent='Пользователь не найден';return;}
  if(users[u].pw!==btoa(unescape(encodeURIComponent(p)))){document.getElementById('linErr').textContent='Неверный пароль';return;}
  await loginUser(u);
}
async function doReg(){
  const u=document.getElementById('rU').value.trim(),p=document.getElementById('rP').value,p2=document.getElementById('rP2').value;
  if(!u||!p){document.getElementById('regErr').textContent='Заполните поля';return;}
  if(u.length<3){document.getElementById('regErr').textContent='Логин мин. 3 символа';return;}
  if(p.length<4){document.getElementById('regErr').textContent='Пароль мин. 4 символа';return;}
  if(p!==p2){document.getElementById('regErr').textContent='Пароли не совпадают';return;}
  const users=await GU()||{};
  if(users[u]){document.getElementById('regErr').textContent='Логин занят';return;}
  users[u]={pw:btoa(unescape(encodeURIComponent(p))),created:Date.now()};
  await SU(users);await loginUser(u);
}
async function loginUser(un){
  CU={username:un};document.getElementById('authMod').classList.remove('open');
  document.getElementById('myVNav').style.display='';
  await renderHeader();await updateMobAv();await checkNotifs();
  toast('👋 '+un,'ok');loadPage(curPage);
}
