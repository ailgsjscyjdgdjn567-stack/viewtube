async function renderAnalytics(){
  if(!CU){document.getElementById('analyticsWrap').innerHTML=`<div class="empty"><div class="ei">🔒</div><h3>Войдите</h3></div>`;return;}
  const myVids=allVids.filter(v=>v.author===CU.username);
  const subs=await GS()||{};const subCount=Object.values(subs).filter(s=>s.includes(CU.username)).length;
  const totalViews=myVids.reduce((s,v)=>s+(v.views||0),0);
  const totalLikes=myVids.reduce((s,v)=>s+(v.likes||0),0);
  const totalComments=0;// approximation
  // Bar chart data — last 7 days views per day
  const days=[];const now=Date.now();
  for(let i=6;i>=0;i--){
    const d=new Date(now-i*86400000);
    const lbl=['Вс','Пн','Вт','Ср','Чт','Пт','Сб'][d.getDay()];
    const dayStart=new Date(d.toDateString()).getTime();
    const dayEnd=dayStart+86400000;
    const views=myVids.reduce((s,v)=>s+(v.dailyViews||[]).filter(dv=>dv>=dayStart&&dv<dayEnd).length,0);
    days.push({lbl,views});
  }
  const maxV=Math.max(...days.map(d=>d.views),1);
  const top=[...myVids].sort((a,b)=>(b.views||0)-(a.views||0)).slice(0,5);
  const w=document.getElementById('analyticsWrap');
  w.innerHTML=`<h2>📊 Аналитика канала</h2><div class="an-sub">Статистика вашего канала @${escH(CU.username)}</div>
  <div class="an-stats">
