    <div class="an-card"><div class="an-val">${subCount}</div><div class="an-lbl">Подписчики</div><div class="an-delta up">↑ актуально</div></div>
    <div class="an-card"><div class="an-val">${totalViews}</div><div class="an-lbl">Просмотры</div></div>
    <div class="an-card"><div class="an-val">${totalLikes}</div><div class="an-lbl">Лайки</div></div>
  </div>
  <div class="chart-card">
    <h3>📈 Просмотры за 7 дней</h3>
    <div class="bar-chart">
      ${days.map(d=>`<div class="bar-wrap"><div class="bar" style="height:${Math.round(d.views/maxV*100)}px;" title="${d.views} просм."></div><div class="bar-lbl">${d.lbl}</div></div>`).join('')}
    </div>
    ${totalViews===0?`<div style="text-align:center;font-size:12px;color:var(--mut);margin-top:8px;">Просмотры появятся когда другие посмотрят ваши видео</div>`:''}
  </div>
  <div class="chart-card">
    <h3>🏆 Топ видео по просмотрам</h3>
    ${top.length?top.map((v,i)=>{
      const vid2=v.type!=='local'?ytId(v.url):null;
      const th=vid2?`<iframe src="https://www.youtube.com/embed/${vid2}?mute=1&controls=0" loading="lazy"></iframe>`:`<div style="font-size:18px;display:flex;align-items:center;justify-content:center;height:100%;">📹</div>`;
      return`<div class="top-vid-row" onclick="watchVideo('${v.id}')">
        <div class="tv-rank">${i+1}</div>
        <div class="tv-thumb">${th}</div>
        <div class="tv-info"><div class="tv-title">${escH(v.title)}</div><div class="tv-stats">👁 ${v.views||0} · ❤️ ${v.likes||0}</div></div>
      </div>`;
    }).join(''):`<div style="text-align:center;padding:20px;color:var(--mut);font-size:13px;">Видео появятся здесь</div>`}
  </div>`;
}

