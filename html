<script>
// ══════════ STATE ══════════
let CU=null,curPage='home',curVid=null,curCat='',allVids=[],upType='link';
let searchSort='new',cmtSortDesc=true;
let uploadTags=[];
let mobFS=false;
let settings={loop:false,quality:'720p',theme:'light',lang:'ru'};
let plModalVidId=null;

const COLORS=['linear-gradient(135deg,#ff4f4f,#ff8c42)','linear-gradient(135deg,#6c63ff,#3ecfcf)','linear-gradient(135deg,#e94560,#f5a623)','linear-gradient(135deg,#11998e,#38ef7d)','linear-gradient(135deg,#4a00e0,#8e2de2)','linear-gradient(135deg,#1c92d2,#a8edea)','linear-gradient(135deg,#f7971e,#ffd200)','linear-gradient(135deg,#c471ed,#f64f59)'];
const gc=s=>{let h=0;for(let c of(s||'?'))h=c.charCodeAt(0)+(h<<6)+(h<<16)-h;return COLORS[Math.abs(h)%COLORS.length];};
const gi=s=>(s||'?').substring(0,2).toUpperCase();
function avH(prof,un){const col=gc(un);if(prof?.avatarDataUrl)return`<img src="${prof.avatarDataUrl}" alt="">`;return`<span style="font-size:12px;">${gi(un)}</span>`;}
function escH(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// ══════════ STORAGE ══════════
async function sg(k,sh=true){try{const r=await window.storage.get(k,sh);return r?JSON.parse(r.value):null;}catch{return null;}}
async function ss(k,v,sh=true){try{await window.storage.set(k,JSON.stringify(v),sh);}catch(e){console.warn(e);}}
const GV=()=>sg('vt6_vids');       const SV=v=>ss('vt6_vids',v);
const GU=()=>sg('vt6_users');      const SU=u=>ss('vt6_users',u);
const GL=()=>sg('vt6_likes');      const SL=l=>ss('vt6_likes',l);
const GDL=()=>sg('vt6_dislikes');  const SDL=l=>ss('vt6_dislikes',l);
const GS=()=>sg('vt6_subs');       const SS=s=>ss('vt6_subs',s);
const GC=id=>sg('vt6_cmts_'+id);   const SC=(id,c)=>ss('vt6_cmts_'+id,c);
const GCR=id=>sg('vt6_cmtR_'+id);  const SCR=(id,r)=>ss('vt6_cmtR_'+id,r);
const GP=un=>sg('vt6_prof_'+un,false);  const SP=(un,p)=>ss('vt6_prof_'+un,p,false);
const GSV=un=>sg('vt6_saved_'+un,false); const SSV=(un,s)=>ss('vt6_saved_'+un,s,false);
const GB=un=>sg('vt6_blobs_'+un,false);  const SB=(un,b)=>ss('vt6_blobs_'+un,b,false);
const GSet=()=>sg('vt6_set',false);  const SSet=v=>ss('vt6_set',v,false);
const GN=un=>sg('vt6_notif_'+un,false);  const SN=(un,n)=>ss('vt6_notif_'+un,n,false);
const GPL=un=>sg('vt6_pl_'+un,false);    const SPL=(un,p)=>ss('vt6_pl_'+un,p,false);

// ══════════ SETTINGS ══════════
async function loadSettings(){
  const s=await GSet();if(s)settings={...settings,...s};
  applyTheme(settings.theme);
  ['loop'].forEach(k=>{const el=document.getElementById('tog-'+k);if(el)el.classList.toggle('on',!!settings[k]);});
  document.querySelectorAll('.qp').forEach(p=>p.classList.toggle('active',p.textContent===settings.quality));
  document.querySelectorAll('.tbtn').forEach(b=>b.classList.toggle('active',b.dataset.theme===settings.theme));
  updateLangUI();
}
async function saveSetting(k,v){settings[k]=v;await SSet(settings);}
function toggleSetting(k){settings[k]=!settings[k];document.getElementById('tog-'+k).classList.toggle('on',settings[k]);saveSetting(k,settings[k]);}
function setQ(q,el){settings.quality=q;document.querySelectorAll('.qp').forEach(p=>p.classList.remove('active'));el.classList.add('active');saveSetting('quality',q);toast('Качество: '+q,'ok');}
function setTheme(theme,el){applyTheme(theme);document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('active'));el?.classList.add('active');saveSetting('theme',theme);}
function applyTheme(t){document.documentElement.setAttribute('data-theme',t);}
function setLang(lang){settings.lang=lang;saveSetting('lang',lang);updateLangUI();toast('✓','ok');}
function updateLangUI(){['ru','en','ky','kz'].forEach(l=>{const el=document.getElementById('lc-'+l);if(el)el.style.display=l===settings.lang?'inline':'none';});}
function clearHistory(){toast('История очищена 🗑','ok');}

