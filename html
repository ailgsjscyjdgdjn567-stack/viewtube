async function pushNotif(toUser,fromUser,vidTitle,vidId){
  if(toUser===fromUser)return;
  const notifs=await GN(toUser)||[];
  notifs.unshift({id:'n'+Date.now(),from:fromUser,vidTitle,vidId,read:false,date:Date.now()});
  await SN(toUser,notifs.slice(0,50));
}
async function checkNotifs(){
  if(!CU)return;
  const notifs=await GN(CU.username)||[];
  const unread=notifs.filter(n=>!n.read).length;
  const dot=document.getElementById('notifDot');const mob=document.getElementById('mobNotifDot');
  if(dot){dot.classList.toggle('show',unread>0);dot.textContent=unread>0?unread:'';}
  if(mob)mob.classList.toggle('show',unread>0);
}
async function renderNotifPanel(){
  if(!CU){document.getElementById('notifPanel').classList.remove('open');return;}
  const notifs=await GN(CU.username)||[];
  const panel=document.getElementById('notifPanel');
  if(!notifs.length){panel.querySelector('.np-body').innerHTML='<div class="no-notifs">🔔 Уведомлений нет</div>';return;}
  const profC={};
  for(const n of notifs.slice(0,20)){if(!profC[n.from])profC[n.from]=await getProf(n.from);}
  panel.querySelector('.np-body').innerHTML=notifs.slice(0,20).map(n=>{
    const p=profC[n.from];const col=gc(n.from);const bg=p?.avatarDataUrl?'transparent':col;
    return`<div class="notif-item ${n.read?'':'unread'}" onclick="openNotifVid('${n.id}','${n.vidId}')">
      <div class="ni-av" style="background:${bg};">${avH(p,n.from)}</div>
      <div style="flex:1;"><div class="ni-txt"><strong>${escH(p?.displayName||n.from)}</strong> загрузил новое видео: «${escH(n.vidTitle)}»</div><div class="ni-time">${ago(n.date)}</div></div>
    </div>`;
  }).join('');
  // Mark all read
  notifs.forEach(n=>n.read=true);await SN(CU.username,notifs);
  await checkNotifs();
