<!DOCTYPE html>
<html lang="ru" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>ViewTube</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 36 36'><rect width='36' height='36' rx='10' fill='%23ff4f4f'/><path d='M10 8L26 18L10 28Z' fill='white'/></svg>">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ══ THEMES ══ */
:root,[data-theme="light"]{--bg:#f5f5f7;--sur:#fff;--s2:#f0f0f3;--s3:#e8e8ec;--acc:#8b5cf6;--acc2:#a78bfa;--txt:#111;--mut:#6b6b80;--bor:#e2e2ea;--grn:#16a34a;--red:#ef4444;--sh:0 4px 20px rgba(0,0,0,.1);--yt:#8b5cf6;}
[data-theme="dark"]{--bg:#0d0d0f;--sur:#16161a;--s2:#1e1e24;--s3:#252530;--acc:#ff4f4f;--acc2:#ff8c42;--txt:#f0f0f5;--mut:#7a7a8c;--bor:#2a2a35;--grn:#4caf81;--red:#ff6b6b;--sh:0 8px 32px rgba(0,0,0,.5);--yt:#ff4f4f;}
[data-theme="amoled"]{--bg:#000;--sur:#0a0a0a;--s2:#111;--s3:#1a1a1a;--acc:#ff4f4f;--acc2:#ff8c42;--txt:#fff;--mut:#666680;--bor:#1e1e1e;--grn:#4caf81;--red:#ff6b6b;--sh:0 8px 32px rgba(0,0,0,.9);--yt:#ff4f4f;}
[data-theme="blue"]{--bg:#0a0e1a;--sur:#111827;--s2:#1a2235;--s3:#243048;--acc:#3b82f6;--acc2:#60a5fa;--txt:#e8f0fe;--mut:#6b7da8;--bor:#1e2d4a;--grn:#34d399;--red:#f87171;--sh:0 8px 32px rgba(0,0,50,.5);--yt:#3b82f6;}
[data-theme="green"]{--bg:#0a120a;--sur:#111a11;--s2:#162016;--s3:#1e2c1e;--acc:#22c55e;--acc2:#86efac;--txt:#e8f5e8;--mut:#6b8a6b;--bor:#1e2e1e;--grn:#22c55e;--red:#f87171;--sh:0 8px 32px rgba(0,30,0,.5);--yt:#22c55e;}
[data-theme="purple"]{--bg:#0d0a14;--sur:#17122a;--s2:#1f1835;--s3:#271f42;--acc:#a855f7;--acc2:#c084fc;--txt:#f0ecff;--mut:#7a6a9a;--bor:#2a1f42;--grn:#4ade80;--red:#f87171;--sh:0 8px 32px rgba(30,0,60,.5);--yt:#a855f7;}
:root{--sb:env(safe-area-inset-bottom,0px);}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--txt);font-family:'DM Sans',sans-serif;min-height:100dvh;transition:background .25s,color .25s;}
button{cursor:pointer;font-family:inherit;border:none;background:none;}
input,textarea,select{font-family:inherit;-webkit-appearance:none;appearance:none;}
img{display:block;}

/* ══ PAGE TRANSITIONS ══ */
.page{display:none;opacity:0;transform:translateY(8px);transition:opacity .22s ease,transform .22s ease;}
.page.active{display:block;animation:pageIn .22s ease forwards;}
@keyframes pageIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ══ MODAL ══ */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:900;align-items:flex-end;justify-content:center;backdrop-filter:blur(10px);}
.ov.open{display:flex;}
@media(min-width:640px){.ov{align-items:center;}}
.modal{background:var(--sur);border:1px solid var(--bor);border-radius:24px 24px 0 0;padding:26px 22px calc(30px + var(--sb));width:100%;max-width:440px;animation:sUp .28s cubic-bezier(.3,1.3,.5,1);overflow-y:auto;max-height:92dvh;}
@media(min-width:640px){.modal{border-radius:24px;padding:34px;}}
@keyframes sUp{from{transform:translateY(60px);opacity:0}to{transform:none;opacity:1}}
.mlogo{display:flex;align-items:center;gap:9px;justify-content:center;margin-bottom:18px;}
.mt{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;text-align:center;margin-bottom:4px;}
.ms{font-size:13px;color:var(--mut);text-align:center;margin-bottom:20px;}
.fi{margin-bottom:12px;}
.fi label{display:block;font-size:11px;font-weight:600;color:var(--mut);letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
.fi input{width:100%;background:var(--s2);border:1.5px solid var(--bor);border-radius:12px;color:var(--txt);padding:12px 15px;font-size:16px;outline:none;transition:border-color .2s;}
.fi input:focus{border-color:var(--acc);}
.btnp{width:100%;background:var(--acc);border:none;border-radius:50px;color:#fff;font-size:15px;font-weight:600;padding:14px;margin-top:4px;}
.btnp:active{opacity:.8;}
.msw{text-align:center;margin-top:12px;font-size:13px;color:var(--mut);}
.msw span{color:var(--acc);cursor:pointer;font-weight:600;}
.em{color:var(--red);font-size:12px;text-align:center;margin-top:6px;min-height:16px;}
.glink button{background:none;border:none;color:var(--mut);font-size:12px;text-decoration:underline;padding:4px;width:100%;text-align:center;margin-top:4px;}

/* ══ HEADER ══ */
header{position:sticky;top:0;z-index:300;background:rgba(245,245,247,.96);backdrop-filter:blur(18px);border-bottom:1px solid var(--bor);height:58px;display:flex;align-items:center;padding:0 16px;gap:12px;transition:background .25s,border-color .25s;}
[data-theme="dark"] header{background:rgba(13,13,15,.96);}
[data-theme="amoled"] header{background:rgba(0,0,0,.98);}
[data-theme="blue"] header{background:rgba(10,14,26,.96);}
[data-theme="green"] header{background:rgba(10,18,10,.96);}
[data-theme="purple"] header{background:rgba(13,10,20,.96);}
.logo{display:flex;align-items:center;gap:8px;cursor:pointer;flex-shrink:0;}
.logo-t{font-family:'Syne',sans-serif;font-weight:800;font-size:19px;letter-spacing:-.5px;}
.logo-t span{color:var(--acc);}
/* Smart search */
.search-wrap{flex:1;position:relative;max-width:520px;}
.sbar{display:flex;align-items:center;background:var(--s2);border:1.5px solid var(--bor);border-radius:50px;overflow:visible;transition:border-color .2s;position:relative;}
.sbar:focus-within{border-color:var(--acc);}
.sbar input{flex:1;background:none;border:none;outline:none;padding:9px 16px;color:var(--txt);font-size:14px;min-width:0;border-radius:50px;}
.sbar input::placeholder{color:var(--mut);}
.sbar button{padding:9px 14px;color:var(--mut);font-size:15px;flex-shrink:0;}
/* Search suggestions dropdown */
.search-dd{position:absolute;top:calc(100% + 6px);left:0;right:0;background:var(--sur);border:1px solid var(--bor);border-radius:14px;box-shadow:var(--sh);z-index:400;display:none;overflow:hidden;}
.search-dd.open{display:block;}
.sddi{padding:10px 16px;font-size:13px;color:var(--txt);cursor:pointer;display:flex;align-items:center;gap:10px;transition:background .1s;}
.sddi:hover{background:var(--s2);}
.sddi .sdd-tag{background:color-mix(in srgb,var(--acc) 12%,transparent);color:var(--acc);border-radius:6px;padding:2px 8px;font-size:11px;font-weight:600;}
/* Search filters */
.search-filters{display:flex;gap:7px;padding:12px 16px 0;flex-wrap:wrap;align-items:center;}
.sf-lbl{font-size:12px;color:var(--mut);font-weight:600;margin-right:4px;}
.sf-pill{padding:5px 13px;border-radius:50px;font-size:12px;font-weight:500;border:1.5px solid var(--bor);background:var(--sur);color:var(--mut);cursor:pointer;transition:all .15s;flex-shrink:0;}
.sf-pill.active{background:var(--acc);border-color:var(--acc);color:#fff;}
.sf-sort{padding:5px 13px;border-radius:50px;font-size:12px;font-weight:500;border:1.5px solid var(--bor);background:var(--sur);color:var(--mut);cursor:pointer;display:flex;align-items:center;gap:4px;}
.hright{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.hbtn{display:flex;align-items:center;gap:5px;border:1.5px solid var(--bor);background:var(--s2);border-radius:50px;color:var(--txt);font-size:13px;font-weight:600;padding:7px 13px;white-space:nowrap;transition:all .15s;}
.hbtn:hover{border-color:var(--acc);color:var(--acc);}
.hbtn-acc{background:var(--acc);border-color:var(--acc);color:#fff;}
.hbtn-acc:hover{opacity:.88;color:#fff;}
/* Notif bell */
.notif-wrap{position:relative;}
.notif-bell{width:36px;height:36px;border-radius:50%;background:var(--s2);border:1.5px solid var(--bor);display:flex;align-items:center;justify-content:center;font-size:17px;transition:all .15s;flex-shrink:0;}
.notif-bell:hover{border-color:var(--acc);}
.notif-dot{position:absolute;top:2px;right:2px;width:10px;height:10px;background:var(--red);border-radius:50%;border:2px solid var(--bg);display:none;animation:pulse .8s ease infinite alternate;}
.notif-dot.show{display:block;}
@keyframes pulse{from{transform:scale(1)}to{transform:scale(1.2)}}
.notif-panel{position:absolute;top:44px;right:0;background:var(--sur);border:1px solid var(--bor);border-radius:16px;width:300px;max-height:400px;overflow-y:auto;box-shadow:var(--sh);z-index:500;display:none;}
.notif-panel.open{display:block;}
.np-head{padding:13px 16px;font-family:'Syne',sans-serif;font-size:14px;font-weight:700;border-bottom:1px solid var(--bor);display:flex;align-items:center;justify-content:space-between;}
.np-clear{font-size:11px;color:var(--mut);cursor:pointer;font-weight:400;}
.np-clear:hover{color:var(--acc);}
.notif-item{padding:11px 14px;display:flex;gap:10px;border-bottom:1px solid var(--bor);cursor:pointer;transition:background .12s;}
.notif-item:hover{background:var(--s2);}
.notif-item.unread{background:color-mix(in srgb,var(--acc) 5%,transparent);}
.ni-av{width:36px;height:36px;border-radius:50%;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:#fff;}
.ni-av img{width:100%;height:100%;object-fit:cover;}
.ni-txt{flex:1;font-size:12px;color:var(--mut);line-height:1.4;}
.ni-txt strong{color:var(--txt);}
.ni-time{font-size:11px;color:var(--mut);margin-top:2px;}
.no-notifs{padding:24px;text-align:center;font-size:13px;color:var(--mut);}
/* Avatar dropdown */
.avwrap{position:relative;}
.avbtn{width:34px;height:34px;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:#fff;}
.avbtn img{width:100%;height:100%;object-fit:cover;}
.dd{position:absolute;top:44px;right:0;background:var(--sur);border:1px solid var(--bor);border-radius:16px;width:220px;overflow:hidden;box-shadow:var(--sh);z-index:500;display:none;}
.dd.open{display:block;}
.dd-head{padding:13px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--bor);}
.dd-av{width:38px;height:38px;border-radius:50%;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:#fff;}
.dd-av img{width:100%;height:100%;object-fit:cover;}
.ddi{padding:11px 16px;font-size:13px;color:var(--txt);cursor:pointer;display:flex;align-items:center;gap:10px;transition:background .1s;}
.ddi:hover{background:var(--s2);}
.ddi.danger{color:var(--red);}
.ddsep{height:1px;background:var(--bor);}

/* ══ LAYOUT ══ */
.wrap{display:flex;min-height:calc(100dvh - 58px);}
aside{width:215px;flex-shrink:0;padding:14px 10px;border-right:1px solid var(--bor);position:sticky;top:58px;height:calc(100dvh - 58px);overflow-y:auto;transition:border-color .25s;}
.nsec{margin-bottom:16px;}
.nlbl{font-size:10px;font-weight:600;letter-spacing:1px;color:var(--mut);text-transform:uppercase;padding:0 12px;margin-bottom:6px;}
.ni{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:12px;cursor:pointer;color:var(--mut);font-size:14px;transition:background .15s,color .15s;}
.ni:hover{background:var(--s2);color:var(--txt);}
.ni.active{background:color-mix(in srgb,var(--acc) 12%,transparent);color:var(--acc);font-weight:600;}
.nico{font-size:17px;width:22px;text-align:center;flex-shrink:0;}
.ni-badge{margin-left:auto;background:var(--red);color:#fff;border-radius:50px;font-size:10px;font-weight:700;padding:1px 7px;min-width:18px;text-align:center;}
main{flex:1;padding:20px 18px;min-width:0;overflow:hidden;}
@media(min-width:900px){main{padding:24px 30px;}}

/* ══ MOBILE NAV ══ */
.mob-nav{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--sur);backdrop-filter:blur(18px);border-top:1px solid var(--bor);padding:6px 0 calc(6px + var(--sb));z-index:300;transition:background .25s;}
.mninner{display:flex;justify-content:space-around;}
.mnb{display:flex;flex-direction:column;align-items:center;gap:3px;color:var(--mut);font-size:10px;font-weight:600;padding:4px 6px;flex:1;max-width:66px;position:relative;}
.mnb .mni{font-size:22px;line-height:1.2;}
.mnb .mni-img{width:26px;height:26px;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:11px;color:#fff;margin:0 auto 2px;}
.mnb .mni-img img{width:100%;height:100%;object-fit:cover;}
.mnb.active{color:var(--acc);}
.mnb:active{opacity:.7;}
.mnb-dot{position:absolute;top:2px;right:12px;width:8px;height:8px;background:var(--red);border-radius:50%;border:2px solid var(--sur);display:none;}
.mnb-dot.show{display:block;}
@media(max-width:699px){aside{display:none;}.mob-nav{display:block;}main{padding:12px 12px 82px;}.wlayout{flex-direction:column;}.wside{width:100%;}.wtitle{font-size:16px;}.actb{font-size:12px;padding:8px 11px;}header{padding:0 10px;gap:7px;}.logo-t{font-size:16px;}.hbtn .hbtxt{display:none;}.search-wrap{max-width:none;}}
@media(min-width:700px){.mob-nav{display:none;}}

/* ══ CATS & GRID ══ */
.cats{display:flex;gap:7px;margin-bottom:16px;overflow-x:auto;scrollbar-width:none;}
.cats::-webkit-scrollbar{display:none;}
.cp{flex-shrink:0;padding:7px 15px;border-radius:50px;font-size:13px;font-weight:500;cursor:pointer;border:1.5px solid var(--bor);background:var(--sur);color:var(--mut);transition:all .2s;}
.cp.active{background:var(--txt);color:var(--bg);border-color:var(--txt);}
.stitle{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;margin-bottom:13px;display:flex;align-items:center;gap:10px;}
.stitle::after{content:'';flex:1;height:1px;background:var(--bor);}
.vg{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,252px),1fr));gap:16px;margin-bottom:28px;}
@media(min-width:600px){.vg{gap:18px;}}
.vc{cursor:pointer;border-radius:14px;overflow:hidden;background:var(--sur);border:1px solid var(--bor);animation:fUp .3s ease both;transition:border-color .25s,box-shadow .2s,transform .2s;}
@media(hover:hover){.vc:hover{transform:translateY(-3px);box-shadow:var(--sh);}}
@keyframes fUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.vthumb{width:100%;aspect-ratio:16/9;position:relative;overflow:hidden;background:#111;}
.vthumb iframe,.vthumb video{width:100%;height:100%;border:none;pointer-events:none;object-fit:cover;}
.vthumb-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:38px;}
.pov{position:absolute;inset:0;background:rgba(0,0,0,0);display:flex;align-items:center;justify-content:center;transition:background .2s;}
.vc:active .pov,.vc:hover .pov{background:rgba(0,0,0,.3);}
.pbtn{width:42px;height:42px;background:var(--acc);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transform:scale(.7);transition:opacity .2s,transform .2s;color:#fff;font-size:15px;}
.vc:hover .pbtn,.vc:active .pbtn{opacity:1;transform:scale(1);}
.yt-badge{position:absolute;top:6px;left:6px;border-radius:6px;padding:2px 7px;font-size:10px;font-weight:700;background:rgba(0,0,0,.72);display:flex;align-items:center;gap:3px;color:#fff;}
.yt-badge svg{fill:var(--yt);}
/* Playlist badge on card */
.pl-badge{position:absolute;bottom:6px;right:6px;background:rgba(0,0,0,.75);border-radius:6px;padding:3px 8px;font-size:11px;font-weight:600;color:#fff;display:flex;align-items:center;gap:4px;}
.cinfo{padding:11px;display:flex;gap:9px;}
.chavs{width:32px;height:32px;border-radius:50%;flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;font-family:'Syne',sans-serif;color:#fff;}
.chavs img{width:100%;height:100%;object-fit:cover;}
.cmeta{flex:1;min-width:0;}
.ctitle{font-size:13px;font-weight:500;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:3px;}
.cchan{font-size:12px;color:var(--mut);margin-bottom:2px;}
.cstats{font-size:11px;color:var(--mut);}
.delbtn{font-size:16px;padding:5px;flex-shrink:0;align-self:flex-start;color:var(--mut);}
.delbtn:active{color:var(--red);}

/* ══ WATCH ══ */
.wlayout{display:flex;gap:22px;}
.wmain{flex:1;min-width:0;}
/* Mobile fullscreen player */
.wplayer{width:100%;aspect-ratio:16/9;border-radius:14px;overflow:hidden;background:#000;margin-bottom:10px;transition:border-radius .2s;}
.wplayer.fullscreen-mob{position:fixed;inset:0;z-index:800;border-radius:0;aspect-ratio:unset;height:100dvh;}
.wplayer iframe,.wplayer video{width:100%;height:100%;border:none;object-fit:contain;}
.mob-fullscreen-btn{display:none;position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,.7);border:none;border-radius:8px;color:#fff;font-size:18px;padding:6px 10px;z-index:5;}
@media(max-width:699px){.mob-fullscreen-btn{display:flex;align-items:center;}}
.wplayer-wrap{position:relative;}
/* YT warn */
.yt-warn{display:none;align-items:center;gap:10px;background:rgba(255,150,0,.1);border:1px solid rgba(255,150,0,.3);border-radius:12px;padding:11px 14px;margin-bottom:12px;font-size:13px;color:#f59e0b;animation:fUp .3s ease;}
.yt-warn.show{display:flex;}
.yt-warn-ico{font-size:18px;flex-shrink:0;}
.yt-warn-txt strong{display:block;font-weight:600;font-size:13px;margin-bottom:1px;}
.yt-warn-txt span{font-size:11px;opacity:.8;}
.yt-warn-open{margin-left:auto;flex-shrink:0;background:rgba(255,150,0,.18);border:1px solid rgba(255,150,0,.35);border-radius:8px;color:#f59e0b;font-size:11px;font-weight:700;padding:5px 10px;}
.wtitle{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:10px;line-height:1.3;}
.wmeta{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;padding-bottom:13px;border-bottom:1px solid var(--bor);margin-bottom:13px;}
.wchinfo{display:flex;align-items:center;gap:10px;}
.wchav{width:40px;height:40px;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;font-family:'Syne',sans-serif;color:#fff;flex-shrink:0;}
.wchav img{width:100%;height:100%;object-fit:cover;}
.wchname{font-size:14px;font-weight:600;}
.wchsubs{font-size:12px;color:var(--mut);}
.wacts{display:flex;align-items:center;gap:7px;flex-wrap:wrap;}
.actb{display:flex;align-items:center;gap:6px;border:1.5px solid var(--bor);background:var(--s2);border-radius:50px;color:var(--txt);font-size:13px;font-weight:500;padding:8px 13px;transition:background .15s,border-color .15s,color .15s;}
.actb.liked{background:color-mix(in srgb,var(--acc) 15%,transparent);border-color:var(--acc);color:var(--acc);}
.actb.disliked{background:color-mix(in srgb,var(--red) 12%,transparent);border-color:var(--red);color:var(--red);}
.actb.subbed{background:color-mix(in srgb,var(--grn) 12%,transparent);border-color:var(--grn);color:var(--grn);}
.actb.saved{background:color-mix(in srgb,#f59e0b 12%,transparent);border-color:#f59e0b;color:#f59e0b;}
.wdesc{background:var(--s2);border-radius:12px;padding:13px;font-size:14px;color:var(--mut);line-height:1.6;margin-bottom:16px;}
/* Add to playlist btn in watch */
.pl-add-row{display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.pl-add-btn{display:flex;align-items:center;gap:5px;border:1.5px solid var(--bor);background:var(--s2);border-radius:50px;color:var(--mut);font-size:12px;font-weight:500;padding:6px 12px;transition:all .15s;}
.pl-add-btn:hover{border-color:var(--acc);color:var(--acc);}
/* Comments */
.comments-section{margin-bottom:22px;}
.comm-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.comm-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;display:flex;align-items:center;gap:7px;}
.comm-sort{font-size:12px;color:var(--mut);cursor:pointer;display:flex;align-items:center;gap:4px;}
.comm-sort:hover{color:var(--acc);}
.comment-form{display:flex;gap:10px;margin-bottom:14px;align-items:flex-start;}
.comm-av{width:32px;height:32px;border-radius:50%;flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:#fff;}
.comm-av img{width:100%;height:100%;object-fit:cover;}
.comm-input-wrap{flex:1;}
.comm-input{width:100%;background:var(--s2);border:1.5px solid var(--bor);border-radius:12px;color:var(--txt);padding:9px 13px;font-size:14px;outline:none;resize:none;transition:border-color .2s,min-height .2s;}
.comm-input:focus{border-color:var(--acc);}
.comm-actions{display:flex;align-items:center;gap:8px;margin-top:6px;justify-content:flex-end;}
.comm-send{background:var(--acc);border:none;border-radius:50px;color:#fff;font-size:12px;font-weight:600;padding:7px 16px;}
.comm-cancel{background:none;border:none;color:var(--mut);font-size:12px;font-weight:500;}
.guest-hint{background:var(--s2);border:1.5px dashed var(--bor);border-radius:12px;padding:13px;text-align:center;font-size:13px;color:var(--mut);}
.guest-hint span{color:var(--acc);cursor:pointer;font-weight:600;}
.comment-item{display:flex;gap:10px;margin-bottom:12px;animation:fUp .22s ease;}
.ci-av{width:32px;height:32px;border-radius:50%;flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:#fff;}
.ci-av img{width:100%;height:100%;object-fit:cover;}
.ci-body{flex:1;}
.ci-name{font-size:13px;font-weight:600;margin-bottom:2px;display:flex;align-items:center;gap:6px;}
.ci-text{font-size:13px;color:var(--mut);line-height:1.5;}
.ci-footer{display:flex;align-items:center;gap:10px;margin-top:6px;}
.ci-time{font-size:11px;color:var(--mut);}
.ci-react{display:flex;align-items:center;gap:4px;font-size:12px;font-weight:500;color:var(--mut);padding:3px 8px;border-radius:50px;transition:background .1s,color .1s;}
.ci-react:hover{background:var(--s2);color:var(--txt);}
.ci-react.active-like{color:var(--acc);}
.ci-react.active-dis{color:var(--red);}
/* Sidebar */
.wside{width:270px;flex-shrink:0;}
.sbtitle{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;margin-bottom:10px;color:var(--mut);}
.svid{display:flex;gap:10px;margin-bottom:10px;cursor:pointer;border-radius:10px;padding:7px;transition:background .15s;}
.svid:hover,.svid:active{background:var(--s2);}
.sthumb{width:108px;aspect-ratio:16/9;border-radius:8px;overflow:hidden;flex-shrink:0;background:#111;display:flex;align-items:center;justify-content:center;font-size:20px;}
.sthumb iframe{width:100%;height:100%;border:none;pointer-events:none;}
.stit{font-size:12px;font-weight:500;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:3px;}
.sch{font-size:11px;color:var(--mut);}

/* ══ ANALYTICS ══ */
.analytics-wrap{max-width:700px;margin:0 auto;padding-bottom:60px;}
.analytics-wrap h2{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;margin-bottom:4px;}
.an-sub{font-size:14px;color:var(--mut);margin-bottom:22px;}
.an-stats{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:22px;}
.an-card{background:var(--sur);border:1px solid var(--bor);border-radius:14px;padding:16px;}
.an-val{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--acc);}
.an-lbl{font-size:12px;color:var(--mut);margin-top:2px;}
.an-delta{font-size:11px;margin-top:4px;font-weight:600;}
.an-delta.up{color:var(--grn);}
.an-delta.dn{color:var(--red);}
/* Simple bar chart */
.chart-card{background:var(--sur);border:1px solid var(--bor);border-radius:14px;padding:16px 20px;margin-bottom:18px;}
.chart-card h3{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;margin-bottom:14px;color:var(--mut);}
.bar-chart{display:flex;align-items:flex-end;gap:6px;height:120px;padding-top:10px;}
.bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;}
.bar{width:100%;border-radius:6px 6px 0 0;background:var(--acc);min-height:4px;transition:height .4s ease;opacity:.85;}
.bar:hover{opacity:1;}
.bar-lbl{font-size:10px;color:var(--mut);text-align:center;}
/* Top videos */
.top-vid-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--bor);}
.top-vid-row:last-child{border-bottom:none;}
.tv-rank{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--acc);width:28px;flex-shrink:0;}
.tv-thumb{width:72px;aspect-ratio:16/9;border-radius:8px;overflow:hidden;flex-shrink:0;background:#111;display:flex;align-items:center;justify-content:center;font-size:18px;}
.tv-thumb iframe{width:100%;height:100%;border:none;pointer-events:none;}
.tv-info{flex:1;min-width:0;}
.tv-title{font-size:13px;font-weight:500;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.tv-stats{font-size:11px;color:var(--mut);margin-top:3px;}

/* ══ PLAYLISTS ══ */
.playlists-wrap{max-width:700px;margin:0 auto;padding-bottom:60px;}
.pl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,220px),1fr));gap:14px;margin-bottom:24px;}
.pl-card{cursor:pointer;border-radius:14px;overflow:hidden;background:var(--sur);border:1px solid var(--bor);animation:fUp .3s ease both;transition:transform .2s,box-shadow .2s;}
@media(hover:hover){.pl-card:hover{transform:translateY(-2px);box-shadow:var(--sh);}}
.pl-thumb{width:100%;aspect-ratio:16/9;position:relative;overflow:hidden;background:linear-gradient(135deg,var(--acc),var(--acc2));display:flex;align-items:center;justify-content:center;font-size:32px;}
.pl-thumb img{width:100%;height:100%;object-fit:cover;}
.pl-count{position:absolute;bottom:0;right:0;background:rgba(0,0,0,.8);color:#fff;font-size:12px;font-weight:700;padding:4px 10px;border-radius:8px 0 0 0;}
.pl-info{padding:11px;}
.pl-name{font-size:14px;font-weight:600;margin-bottom:3px;}
.pl-meta{font-size:12px;color:var(--mut);}
/* Create playlist form */
.pl-create-card{background:var(--sur);border:1px solid var(--bor);border-radius:14px;padding:18px;margin-bottom:18px;}
.pl-create-card h3{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:12px;}
.pi{margin-bottom:11px;}
.pi label{display:block;font-size:11px;font-weight:600;color:var(--mut);letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
.pi input,.pi select{width:100%;background:var(--s2);border:1.5px solid var(--bor);border-radius:10px;color:var(--txt);padding:10px 13px;font-size:15px;outline:none;transition:border-color .2s;}
.pi input:focus{border-color:var(--acc);}
.pi select option{background:var(--s2);}
/* Playlist detail */
.pl-detail-wrap{max-width:700px;margin:0 auto;padding-bottom:60px;}
.pl-detail-header{display:flex;gap:16px;margin-bottom:20px;flex-wrap:wrap;}
.pl-detail-cover{width:160px;aspect-ratio:16/9;border-radius:12px;overflow:hidden;background:linear-gradient(135deg,var(--acc),var(--acc2));flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:32px;}
.pl-detail-cover img{width:100%;height:100%;object-fit:cover;}
.pl-detail-info{flex:1;}
.pl-detail-name{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;margin-bottom:5px;}
.pl-detail-meta{font-size:13px;color:var(--mut);margin-bottom:12px;}
.pl-vid-row{display:flex;align-items:center;gap:12px;padding:9px;border-radius:10px;cursor:pointer;transition:background .12s;}
.pl-vid-row:hover{background:var(--s2);}
.pl-vid-num{width:22px;text-align:center;font-size:12px;color:var(--mut);flex-shrink:0;}
.pl-vid-thumb{width:100px;aspect-ratio:16/9;border-radius:8px;overflow:hidden;flex-shrink:0;background:#111;display:flex;align-items:center;justify-content:center;font-size:18px;}
.pl-vid-thumb iframe{width:100%;height:100%;border:none;pointer-events:none;}
.pl-remove{color:var(--mut);font-size:15px;padding:4px;flex-shrink:0;}
.pl-remove:active{color:var(--red);}
/* Add to playlist modal */
.pl-modal-list{max-height:260px;overflow-y:auto;padding:4px;}
.plm-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:10px;cursor:pointer;transition:background .12s;}
.plm-item:hover{background:var(--s2);}
.plm-check{width:18px;height:18px;border-radius:5px;border:2px solid var(--bor);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;transition:all .15s;}
.plm-check.on{background:var(--acc);border-color:var(--acc);color:#fff;}
.plm-name{font-size:13px;font-weight:500;}
.plm-count{font-size:11px;color:var(--mut);margin-left:auto;}

/* ══ UPLOAD ══ */
.upform{max-width:540px;margin:0 auto;padding-bottom:70px;}
.upform h2{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;margin-bottom:5px;}
.upform p{color:var(--mut);font-size:14px;margin-bottom:18px;}
.uptype{display:flex;gap:10px;margin-bottom:16px;}
.uptab{flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;padding:14px 10px;border:2px solid var(--bor);border-radius:14px;background:var(--sur);color:var(--mut);cursor:pointer;font-size:13px;font-weight:600;transition:all .2s;}
.uptab .utico{font-size:24px;line-height:1;}
.uptab.active{border-color:var(--acc);color:var(--acc);}
.uppanel{display:none;}
.uppanel.active{display:block;}
.uf{margin-bottom:14px;}
.uf label{display:block;font-size:11px;font-weight:600;color:var(--mut);letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
.uf input,.uf textarea,.uf select{width:100%;background:var(--s2);border:1.5px solid var(--bor);border-radius:12px;color:var(--txt);padding:12px 15px;font-size:16px;outline:none;transition:border-color .2s;}
.uf input:focus,.uf textarea:focus,.uf select:focus{border-color:var(--acc);}
.uf textarea{resize:vertical;min-height:70px;}
.uf select option{background:var(--s2);}
/* Tags input */
.tags-wrap{display:flex;flex-wrap:wrap;gap:6px;background:var(--s2);border:1.5px solid var(--bor);border-radius:12px;padding:8px 12px;cursor:text;min-height:46px;align-items:center;transition:border-color .2s;}
.tags-wrap:focus-within{border-color:var(--acc);}
.tag-pill{background:color-mix(in srgb,var(--acc) 15%,transparent);color:var(--acc);border-radius:6px;padding:3px 8px;font-size:12px;font-weight:600;display:flex;align-items:center;gap:4px;}
.tag-pill button{background:none;border:none;color:var(--acc);font-size:14px;line-height:1;padding:0;}
#tagInput{background:none;border:none;outline:none;color:var(--txt);font-size:14px;min-width:80px;flex:1;}
.prevbox{width:100%;aspect-ratio:16/9;border-radius:12px;overflow:hidden;background:var(--s2);border:2px dashed var(--bor);display:flex;align-items:center;justify-content:center;color:var(--mut);font-size:13px;margin-bottom:13px;}
.prevbox.hc{border-style:solid;}
.prevbox iframe,.prevbox video{width:100%;height:100%;border:none;}
.dz{width:100%;border:2px dashed var(--bor);border-radius:14px;padding:26px 18px;text-align:center;cursor:pointer;background:var(--s2);margin-bottom:13px;transition:all .2s;}
.dz:hover,.dz.drag{border-color:var(--acc);}
.dz .di{font-size:30px;margin-bottom:7px;}
.dz .dt{font-size:14px;font-weight:600;color:var(--txt);margin-bottom:3px;}
.dz .ds{font-size:12px;color:var(--mut);}
.dz .df{margin-top:7px;font-size:12px;color:var(--grn);font-weight:500;}
#fileIn{display:none;}
.pbar{width:100%;height:5px;background:var(--bor);border-radius:50px;overflow:hidden;margin-bottom:13px;display:none;}
.pfill{height:100%;background:linear-gradient(90deg,var(--acc),var(--acc2));width:0%;transition:width .3s;border-radius:50px;}

/* ══ PROFILE ══ */
.prof-wrap{max-width:600px;margin:0 auto;padding-bottom:50px;}
.prof-cover{width:100%;height:150px;border-radius:14px;overflow:hidden;position:relative;cursor:pointer;background:linear-gradient(135deg,var(--acc),var(--acc2));margin-bottom:0;}
@media(min-width:600px){.prof-cover{height:190px;}}
.prof-cover img{width:100%;height:100%;object-fit:cover;}
.prof-cover-btn{position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,.65);border-radius:8px;color:#fff;font-size:12px;font-weight:600;padding:6px 12px;}
.prof-av-row{display:flex;align-items:flex-end;gap:14px;padding:0 4px;margin-top:-36px;margin-bottom:14px;position:relative;z-index:2;}
.prof-av-wrap{position:relative;flex-shrink:0;}
.prof-av{width:76px;height:76px;border-radius:50%;border:4px solid var(--bg);overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:26px;color:#fff;cursor:pointer;background:var(--acc);transition:border-color .25s;}
.prof-av img{width:100%;height:100%;object-fit:cover;}
.prof-av-edit{position:absolute;bottom:2px;right:2px;width:24px;height:24px;border-radius:50%;background:var(--acc);border:2px solid var(--bg);display:flex;align-items:center;justify-content:center;font-size:11px;cursor:pointer;}
.prof-name{flex:1;padding-bottom:6px;}
.prof-uname{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;}
.prof-bio{font-size:12px;color:var(--mut);margin-top:2px;}
.prof-stats{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;}
.ps{text-align:center;background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:12px 16px;flex:1;min-width:75px;}
.ps-v{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--acc);}
.ps-l{font-size:11px;color:var(--mut);margin-top:1px;}
.prof-tabs{display:flex;gap:0;border-bottom:1px solid var(--bor);margin-bottom:18px;overflow-x:auto;scrollbar-width:none;}
.prof-tabs::-webkit-scrollbar{display:none;}
.ptab{padding:10px 16px;font-size:13px;font-weight:600;color:var(--mut);cursor:pointer;border-bottom:2px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap;flex-shrink:0;}
.ptab.active{color:var(--acc);border-bottom-color:var(--acc);}
.prof-card{background:var(--sur);border:1px solid var(--bor);border-radius:14px;padding:18px;margin-bottom:16px;}
.prof-card h3{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:14px;}
.pf{margin-bottom:12px;}
.pf label{display:block;font-size:11px;font-weight:600;color:var(--mut);letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
.pf input,.pf textarea{width:100%;background:var(--s2);border:1.5px solid var(--bor);border-radius:12px;color:var(--txt);padding:11px 15px;font-size:16px;outline:none;transition:border-color .2s;}
.pf input:focus,.pf textarea:focus{border-color:var(--acc);}
.pf textarea{resize:vertical;min-height:65px;}
.save-btn{background:var(--acc);border:none;border-radius:50px;color:#fff;font-size:14px;font-weight:600;padding:11px 26px;}
.save-btn:active{opacity:.8;}
#coverIn,#avIn{display:none;}
.saved-item{display:flex;gap:10px;padding:9px;border-radius:12px;background:var(--sur);border:1px solid var(--bor);margin-bottom:9px;cursor:pointer;transition:border-color .15s;}
.saved-item:hover{border-color:var(--acc);}
.sv-thumb{width:100px;aspect-ratio:16/9;border-radius:8px;overflow:hidden;flex-shrink:0;background:#111;display:flex;align-items:center;justify-content:center;font-size:18px;}
.sv-thumb iframe{width:100%;height:100%;border:none;pointer-events:none;}
.sv-info{flex:1;min-width:0;}
.sv-title{font-size:13px;font-weight:500;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:3px;}
.sv-chan{font-size:11px;color:var(--mut);}
.unsave-btn{flex-shrink:0;align-self:flex-start;padding:5px;color:var(--mut);font-size:15px;}

/* ══ SETTINGS ══ */
.set-wrap{max-width:540px;margin:0 auto;padding-bottom:60px;}
.set-wrap h2{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;margin-bottom:4px;}
.set-sub{font-size:14px;color:var(--mut);margin-bottom:20px;}
.set-card{background:var(--sur);border:1px solid var(--bor);border-radius:14px;overflow:hidden;margin-bottom:14px;transition:border-color .25s;}
.set-head{padding:12px 17px;font-size:11px;font-weight:700;color:var(--mut);letter-spacing:.8px;text-transform:uppercase;border-bottom:1px solid var(--bor);}
.set-row{display:flex;align-items:center;padding:12px 17px;gap:12px;border-bottom:1px solid var(--bor);transition:background .12s;}
.set-row:last-child{border-bottom:none;}
.set-row.click:hover{background:var(--s2);cursor:pointer;}
.s-ico{font-size:19px;width:26px;text-align:center;flex-shrink:0;}
.s-info{flex:1;min-width:0;}
.s-lbl{font-size:14px;font-weight:500;color:var(--txt);}
.s-desc{font-size:12px;color:var(--mut);margin-top:1px;}
.s-right{flex-shrink:0;display:flex;align-items:center;gap:8px;}
.tog{width:42px;height:23px;background:var(--bor);border-radius:50px;position:relative;cursor:pointer;transition:background .2s;flex-shrink:0;}
.tog.on{background:var(--acc);}
.tog::after{content:'';position:absolute;width:17px;height:17px;border-radius:50%;background:#fff;top:3px;left:3px;transition:transform .2s;}
.tog.on::after{transform:translateX(19px);}
.theme-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;padding:14px 17px;}
.tbtn{display:flex;flex-direction:column;align-items:center;gap:6px;padding:10px 6px;border-radius:11px;border:2px solid var(--bor);background:var(--s2);cursor:pointer;font-size:12px;font-weight:600;color:var(--mut);transition:all .2s;}
.tbtn.active{border-color:var(--acc);color:var(--acc);}
.tswatch{width:32px;height:32px;border-radius:50%;}
.acc-list{padding:6px;}
.acc-item{display:flex;align-items:center;gap:11px;padding:10px;border-radius:11px;cursor:pointer;transition:background .12s;}
.acc-item:hover{background:var(--s2);}
.acc-item.cur{background:color-mix(in srgb,var(--acc) 8%,transparent);}
.ai-av{width:38px;height:38px;border-radius:50%;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:#fff;}
.ai-av img{width:100%;height:100%;object-fit:cover;}
.ai-info{flex:1;}
.ai-name{font-size:13px;font-weight:600;}
.ai-user{font-size:11px;color:var(--mut);}
.acc-add{display:flex;align-items:center;gap:11px;padding:10px;color:var(--mut);font-size:13px;font-weight:500;border-top:1px solid var(--bor);margin-top:3px;cursor:pointer;border-radius:0 0 11px 11px;transition:background .12s;width:100%;}
.acc-add:hover{background:var(--s2);color:var(--txt);}
.qp{padding:5px 12px;border-radius:50px;font-size:12px;font-weight:600;border:1.5px solid var(--bor);background:var(--s2);color:var(--mut);cursor:pointer;transition:all .2s;}
.qp.active{border-color:var(--acc);color:var(--acc);}
.lang-list{padding:8px 17px 14px;}
.lang-btn{display:flex;align-items:center;gap:12px;width:100%;padding:10px 12px;border-radius:11px;font-size:14px;font-weight:500;color:var(--txt);transition:background .12s;}
.lang-btn:hover{background:var(--s2);}
.lang-flag{font-size:20px;width:28px;}
.lang-soon{text-align:center;font-size:12px;color:var(--mut);padding:10px 17px 14px;border-top:1px solid var(--bor);}

/* ══ MISC ══ */
.empty{text-align:center;padding:44px 20px;color:var(--mut);grid-column:1/-1;}
.empty .ei{font-size:44px;margin-bottom:10px;}
.empty h3{font-family:'Syne',sans-serif;font-size:15px;color:var(--txt);margin-bottom:4px;}
.loading{text-align:center;padding:32px;color:var(--mut);font-size:14px;grid-column:1/-1;}
.toast{position:fixed;bottom:calc(70px + var(--sb));left:50%;transform:translateX(-50%) translateY(20px);background:var(--sur);border:1px solid var(--bor);border-radius:50px;padding:10px 20px;font-size:13px;font-weight:500;z-index:9999;transition:transform .25s,opacity .25s;opacity:0;pointer-events:none;box-shadow:var(--sh);white-space:nowrap;max-width:90vw;overflow:hidden;text-overflow:ellipsis;}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1;}
.toast.ok{border-color:var(--grn);color:var(--grn);}
.toast.err{border-color:var(--red);color:var(--red);}
