let allTags=[];
function buildTagIndex(){
  allTags=[...new Set(allVids.flatMap(v=>v.tags||[]))].filter(Boolean);
}
function showSearchDD(){
  const q=document.getElementById('searchIn').value.trim();
  const dd=document.getElementById('searchDD');
  if(!q){dd.classList.remove('open');return;}
  const cats=['Технологии','Игры','Музыка','Образование','Кино','Спорт','Наука','Разное'];
  const matchCats=cats.filter(c=>c.toLowerCase().includes(q.toLowerCase()));
  const matchTags=allTags.filter(t=>t.toLowerCase().includes(q.toLowerCase())).slice(0,4);
  const matchVids=allVids.filter(v=>(v.title||'').toLowerCase().includes(q.toLowerCase())).slice(0,3);
  let html='';
  if(matchCats.length)html+=matchCats.map(c=>`<div class="sddi" onclick="fCatStr('${c}')">🗂 <span class="sdd-tag">Категория</span>${escH(c)}</div>`).join('');
  if(matchTags.length)html+=matchTags.map(t=>`<div class="sddi" onclick="searchByTag('${escH(t)}')">🏷 <span class="sdd-tag">Тег</span>${escH(t)}</div>`).join('');
  if(matchVids.length)html+=matchVids.map(v=>`<div class="sddi" onclick="watchVideo('${v.id}')">🎬 ${escH(v.title)}</div>`).join('');
  if(!html){dd.classList.remove('open');return;}
  dd.innerHTML=html;dd.classList.add('open');
}
function hideSearchDD(){document.getElementById('searchDD').classList.remove('open');}
function handleSearchKey(e){if(e.key==='Enter'){hideSearchDD();onSearch();}}
function fCatStr(cat){fCat(document.querySelector(`.cp[onclick*="${cat}"]`)||document.querySelector('.cp'),cat);document.getElementById('searchIn').value='';}
function searchByTag(tag){document.getElementById('searchIn').value=tag;onSearch();}

function onSearch(){
  const q=document.getElementById('searchIn').value.trim();
  const sf=document.getElementById('searchFilters');
  sf.style.display=q?'flex':'none';
  if(q){document.getElementById('homeTitle').textContent='Результаты: «'+q+'»';}
  else{document.getElementById('homeTitle').textContent='Все видео';}
  loadPage('home');showSearchDD();
}
