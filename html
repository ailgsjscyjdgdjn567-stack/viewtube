// ══════════ NAVIGATION ══════════
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>{p.classList.remove('active');});
  document.querySelectorAll('.ni,.mnb').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+name)?.classList.add('active');
  document.getElementById('nav-'+name)?.classList.add('active');
  document.getElementById('mnav-'+name)?.classList.add('active');
  if(['myvideos','profile','analytics'].includes(name))document.getElementById('mnav-profile')?.classList.add('active');
  curPage=name;loadPage(name);window.scrollTo(0,0);
}
async function loadPage(name){
  allVids=await GV()||[];buildTagIndex();
  if(name==='home')renderGrid('homeG',applyF(allVids));
  if(name==='trending')renderGrid('trendG',[...allVids].sort((a,b)=>(b.likes||0)-(a.likes||0)).slice(0,30));
  if(name==='subs')await renderSubs();
  if(name==='myvideos'){if(!CU){renderGrid('myG',[]);return;}renderGrid('myG',allVids.filter(v=>v.author===CU.username),true);}
  if(name==='playlists')await renderPlaylists();
  if(name==='analytics')await renderAnalytics();
  if(name==='profile')await renderProfile();
  if(name==='settings')await renderSettings();
}
function applyF(vids){
  let r=curCat?vids.filter(v=>v.category===curCat):vids;
  const q=document.getElementById('searchIn').value.toLowerCase().trim();
  if(q)r=r.filter(v=>(v.title||'').toLowerCase().includes(q)||(v.author||'').toLowerCase().includes(q)||((v.tags||[]).some(t=>t.toLowerCase().includes(q))));
  if(searchSort==='popular')r=[...r].sort((a,b)=>(b.views||0)-(a.views||0));
  else if(searchSort==='liked')r=[...r].sort((a,b)=>(b.likes||0)-(a.likes||0));
  else r=[...r].sort((a,b)=>b.date-a.date);
  return r;
}
function fCat(el,cat){document.querySelectorAll('.cp').forEach(p=>p.classList.remove('active'));if(el)el.classList.add('active');curCat=cat;loadPage('home');}

// ══════════ GRID (with dedup & lazy loading) ══════════
async function renderGrid(gid,videos,showDel=false){
  const el=document.getElementById(gid);if(!el)return;
  if(!videos.length){el.innerHTML=`<div class="empty"><div class="ei">📭</div><h3>Видео нет</h3></div>`;return;}
  const seen=new Set();
  const uniq=videos.filter(v=>{const k=v.type==='local'?v.id:(ytId(v.url)||v.id);if(seen.has(k))return false;seen.add(k);return true;});
  const authors=[...new Set(uniq.map(v=>v.author))];
  const pm={};for(const a of authors)pm[a]=await getProf(a);
  el.innerHTML=uniq.map((v,i)=>cardHTML(v,i,showDel,pm[v.author])).join('');
}
function cardHTML(v,i,showDel,prof){
  let tc;
  if(v.type==='local')tc=`<div class="vthumb-ph">📹</div>`;
  else{const vid=ytId(v.url);tc=vid?`<iframe src="https://www.youtube.com/embed/${vid}?mute=1&controls=0" loading="lazy" allowfullscreen></iframe>`:`<div class="vthumb-ph">🎬</div>`;}
  const col=gc(v.author);const bg=prof?.avatarDataUrl?'transparent':col;
  const del=showDel?`<button class="delbtn" onclick="event.stopPropagation();delVid('${v.id}')">🗑</button>`:'';
  const ytBadge=v.type!=='local'?`<div class="yt-badge"><svg width="10" height="7" viewBox="0 0 22 16"><rect width="22" height="16" rx="3"/><polygon points="9,4 17,8 9,12" fill="white"/></svg> YT</div>`:'';
  const tags=v.tags?.length?`<div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:3px;">${v.tags.slice(0,2).map(t=>`<span style="background:color-mix(in srgb,var(--acc) 10%,transparent);color:var(--acc);border-radius:4px;padding:1px 6px;font-size:10px;">#${escH(t)}</span>`).join('')}</div>`:'';
  return`<div class="vc" onclick="watchVideo('${v.id}')" style="animation-delay:${Math.min(i,.8)*0.05}s">
    <div class="vthumb">${tc}${ytBadge}<div class="pov"><div class="pbtn">▶</div></div></div>
    <div class="cinfo">
      <div class="chavs" style="background:${bg};">${avH(prof,v.author)}</div>
      <div class="cmeta">
        <div class="ctitle">${escH(v.title)}</div>
        <div class="cchan">${escH(prof?.displayName||v.author)}</div>
        <div class="cstats">❤️ ${v.likes||0} · 👁 ${v.views||0} · ${ago(v.date)}</div>
        ${tags}
      </div>${del}
    </div></div>`;
}

